servers/**/session.lock
servers/**/eula.txt
!servers/**/eula.txt.example

# Runtime worlds - exact Project Wayfarer names
# Keep these paths explicit so the server configuration directories themselves
# (servers/lobby, servers/main, servers/frontier) are never ignored.
servers/lobby/lobby/
servers/main/main/
servers/main/main_nether/
servers/main/main_end/
servers/main/resource/
servers/main/resource_nether/
servers/main/resource_end/
servers/frontier/frontier_gate/
servers/frontier/frontier_*/
servers/lab/lab/
servers/lab/lab_*/

# Other default/generated worlds and world internals
servers/**/world/
servers/**/world_nether/
servers/**/world_the_end/
servers/**/level.dat
servers/**/level.dat_old
servers/**/uid.dat
servers/**/region/
servers/**/entities/
servers/**/poi/
servers/**/playerdata/
servers/**/stats/
servers/**/advancements/

