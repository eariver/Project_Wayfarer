# Secrets and machine-local overrides
.env
.env.*
!.env.example
local/paths.psd1
local/*.local.*
**/forwarding.secret
**/forwarding.secret.txt
**/*secret*.local.*
**/credentials/
**/secrets/

# Server and Plugin binaries / paid content
*.jar
*.zip
*.7z
*.rar
*.tar
*.tar.gz
manual-downloads/
licensed-content/
paid-content/

# Runtime server files
velocity/logs/
velocity/lang/
velocity/plugins/bStats/
servers/**/logs/
servers/**/crash-reports/
